# Normalize line endings to LF on commit; check out as-is.
* text=auto eol=lf

*.php   text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.pot   text eol=lf
*.svg   text eol=lf

# Binary assets
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
